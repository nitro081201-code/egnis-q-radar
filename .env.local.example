# 이 파일은 예시입니다. 실제 값은 .env.local 파일에 직접 입력하세요.
# .env.local 파일은 git에 커밋되지 않습니다.

# 공공데이터포털 인증키 (data.go.kr 활용신청 후 발급)
DATA_GO_KR_API_KEY=

# 식품안전나라(foodsafetykorea.go.kr) Open API 키 — 공공데이터포털 키와 별개로 발급받아야 함.
# 행정처분(식품접객업) 등 LINK형 데이터셋에 필요 (docs/data-sources.md 참고)
FOODSAFETYKOREA_API_KEY=

# 법제처 국가법령정보센터 API 인증키 (승인 후)
LAW_GO_KR_API_KEY=

# Supabase 프로젝트 설정 (Supabase 대시보드 > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 서버 전용 키 — 절대 클라이언트에 노출 금지 (Vercel 환경변수에만 등록)
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron 요청 인증용 임의의 긴 문자열 (직접 생성)
CRON_SECRET=

# 로그인 링크(magic link)에 사용할 배포 주소. 비워두면 요청 헤더의 host로 추정한다.
# 프로덕션에서는 반드시 명시할 것 (예: https://q-radar.egnis.kr)
NEXT_PUBLIC_SITE_URL=

# 이메일 매직링크 로그인 on/off. 비워두면 켜짐(기본). 끄려면 false.
# ⚠️ 대체 수단(Google 로그인 등)이 동작하기 전에 끄면 아무도 로그인할 수 없다.
#    배경·되살리는 법: docs/auth-magic-link.md
AUTH_MAGIC_LINK_ENABLED=

# Google 로그인 on/off. 비워두면 꺼짐(기본). 켜려면 true.
# ⚠️ Supabase에서 Google provider를 실제로 활성화한 뒤에만 켤 것.
#    설정 절차: docs/auth-google-login.md
AUTH_GOOGLE_ENABLED=

# @egnis.kr 도메인 외에 로그인을 추가 허용할 이메일 목록(쉼표 구분).
# 개인 계정 등은 코드에 넣지 말고 여기(=Vercel 환경변수)에만 등록한다.
# 예: LOGIN_ALLOWED_EMAILS="someone@example.com,other@example.com"
LOGIN_ALLOWED_EMAILS=
