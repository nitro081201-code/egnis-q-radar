# 이 파일은 예시입니다. 실제 값은 .env.local 파일에 직접 입력하세요.
# .env.local 파일은 git에 커밋되지 않습니다.

# 공공데이터포털 인증키 (data.go.kr 활용신청 후 발급)
DATA_GO_KR_API_KEY=

# 법제처 국가법령정보센터 API 인증키 (승인 후)
LAW_GO_KR_API_KEY=

# Supabase 프로젝트 설정 (Supabase 대시보드 > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 서버 전용 키 — 절대 클라이언트에 노출 금지 (Vercel 환경변수에만 등록)
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron 요청 인증용 임의의 긴 문자열 (직접 생성)
CRON_SECRET=

# 로그인 허용 이메일 (콤마로 구분)
ALLOWED_EMAILS=jhcho@egnis.kr
